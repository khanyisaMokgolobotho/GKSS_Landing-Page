//GKSS Landing page made for Tech Expo
/*The page is divided into clear sections:
Navigation
Hero (main visual + CTA)
Experience section
Organisations section
Sponsors section
Final CTA
Footer*/

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Garankuwa Career Tech Expo 2026</title>
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;700;900&family=Barlow:wght@400;500;700&display=swap" rel="stylesheet">
<style>
  :root {
    --black: #0a0a0a;
    --white: #f0ece0;
    --red: #cc1a1a;
    --red-bright: #ff2828;
    --gold: #d4910a;
    --gold-bright: #f5a623;
    --gray: #1a1a1a;
    --text-muted: rgba(240,236,224,0.55);
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }

  body {
    background: var(--black);
    color: var(--white);
    font-family: 'Barlow', sans-serif;
    overflow-x: hidden;
    cursor: crosshair;
  }

  /* This creates a retro screen */
  body::after {
    content: '';
    position: fixed;
    inset: 0;
    background: repeating-linear-gradient(
      to bottom,
      transparent 0px,
      transparent 3px,
      rgba(0,0,0,0.08) 3px,
      rgba(0,0,0,0.08) 4px
    );
    pointer-events: none;
    z-index: 999;
  }

  /* navigation */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 200;
    display: flex; justify-content: space-between; align-items: stretch;
    height: 56px;
    background: var(--black);
    border-bottom: 2px solid var(--white);
  }
  .nav-left {
    display: flex; align-items: stretch;
    border-right: 2px solid var(--white);
    padding: 0 1.5rem;
    gap: 0;
  }
  .nav-segment {
    display: flex; align-items: center;
    padding: 0 1.2rem;
    border-right: 1px solid rgba(240,236,224,0.15);
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 0.85rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }
  .nav-segment:last-child { border-right: none; }
  .nav-segment.expo { color: var(--gold-bright); }
  .nav-segment.gkss { color: var(--red-bright); }
  .nav-cta-wrap {
    display: flex; align-items: center;
    padding: 0 1.5rem;
  }
  .nav-register {
    background: var(--white);
    color: var(--black);
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: 0.85rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    padding: 0.5rem 1.5rem;
    border: none;
    cursor: crosshair;
    text-decoration: none;
    transition: all 0.15s;
    display: block;
  }
  .nav-register:hover { background: var(--red-bright); color: var(--white); }

  /* HERO SECTION: the conversion driver */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    padding-top: 56px;
    overflow: hidden;
  }

  /* RED BURST BACKGROUND: Adds motion without animation, to create the brutalist view */
  .burst-bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
  }
  .burst-bg svg {
    position: absolute;
    width: 100%; height: 100%;
    opacity: 0.06;
  }

  /* TOP BAR */
  .hero-topbar {
    background: var(--red);
    padding: 0.5rem 4%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 0.75rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    font-weight: 700;
  }

  /* MAIN HERO CONTENT */
  .hero-content {
    flex: 1;
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    position: relative;
    z-index: 2;
  }
  @media (max-width: 768px) { .hero-content { grid-template-columns: 1fr; } }

  .hero-left {
    padding: 4rem 4%;
    border-right: 2px solid rgba(240,236,224,0.1);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .stamp-row {
    display: flex; gap: 0.8rem; margin-bottom: 2rem; flex-wrap: wrap;
  }
  .stamp {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: 0.65rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    padding: 0.3rem 0.8rem;
    border: 2px solid;
  }
  .stamp.gold { border-color: var(--gold-bright); color: var(--gold-bright); }
  .stamp.red { border-color: var(--red-bright); color: var(--red-bright); }
  .stamp.white { border-color: var(--white); color: var(--white); }

  .hero-h1 {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: clamp(5rem, 13vw, 11rem);
    line-height: 0.88;
    letter-spacing: -0.01em;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
  }
  .hero-h1 .w1 { color: var(--white); display: block; }
  .hero-h1 .w2 { color: var(--gold-bright); display: block; -webkit-text-stroke: 0; }
  .hero-h1 .w3 {
    display: block;
    -webkit-text-stroke: 2px var(--white);
    color: transparent;
  }

  .hero-desc {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--text-muted);
    max-width: 480px;
    margin-bottom: 2.5rem;
  }

  .hero-cta-row { display: flex; gap: 1rem; flex-wrap: wrap; }

  .brutal-btn {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: 0.9rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    padding: 0.9rem 2rem;
    border: 2px solid;
    cursor: crosshair;
    text-decoration: none;
    transition: all 0.15s;
    display: inline-block;
  }
  .brutal-btn.primary { background: var(--white); color: var(--black); border-color: var(--white); }
  .brutal-btn.primary:hover { background: var(--red-bright); color: var(--white); border-color: var(--red-bright); }
  .brutal-btn.outline { background: transparent; color: var(--white); border-color: rgba(240,236,224,0.4); }
  .brutal-btn.outline:hover { border-color: var(--gold-bright); color: var(--gold-bright); }

  /* HERO RIGHT */
  .hero-right {
    display: flex;
    flex-direction: column;
    position: relative;
    overflow: hidden;
  }

  .hero-date-block {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 3rem 2rem;
    position: relative;
    overflow: hidden;
    background: radial-gradient(ellipse at center, rgba(212,145,10,0.08) 0%, transparent 70%);
  }

  .big-date {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: clamp(4rem, 10vw, 9rem);
    line-height: 1;
    letter-spacing: -0.03em;
    text-align: center;
    position: relative;
    z-index: 2;
  }
  .big-date .day { color: var(--gold-bright); display: block; }
  .big-date .mo {
    color: var(--white);
    font-size: 0.4em;
    letter-spacing: 0.3em;
    display: block;
    margin-top: -0.1em;
  }
  .big-date .yr {
    color: rgba(240,236,224,0.25);
    font-size: 0.3em;
    letter-spacing: 0.5em;
    display: block;
  }

  .crosshair-box {
    position: absolute;
    width: 80%;
    height: 80%;
    border: 1px solid rgba(240,236,224,0.08);
  }
  .crosshair-box::before, .crosshair-box::after {
    content: '';
    position: absolute;
    background: rgba(212,145,10,0.15);
  }
  .crosshair-box::before { width: 100%; height: 1px; top: 50%; }
  .crosshair-box::after { width: 1px; height: 100%; left: 50%; }

  .hero-right-bottom {
    background: var(--red);
    padding: 1.5rem 2rem;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    border-top: 2px solid var(--red-bright);
  }
  .hrb-stat {
    text-align: center;
    border-right: 1px solid rgba(255,255,255,0.2);
    padding: 0.5rem;
  }
  .hrb-stat:last-child { border-right: none; }
  .hrb-n {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: 1.8rem;
    line-height: 1;
    letter-spacing: -0.02em;
  }
  .hrb-l { font-size: 0.65rem; letter-spacing: 0.15em; text-transform: uppercase; color: rgba(255,255,255,0.6); margin-top: 0.2rem; }

  /* EXPERIENCE SECTION */
  .exp-section {
    position: relative;
    border-top: 2px solid rgba(240,236,224,0.1);
  }

  .exp-header {
    display: grid;
    grid-template-columns: auto 1fr;
    align-items: center;
    padding: 3rem 4%;
    gap: 2rem;
    border-bottom: 1px solid rgba(240,236,224,0.1);
  }
  .exp-header-num {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: clamp(4rem, 10vw, 8rem);
    color: rgba(240,236,224,0.06);
    line-height: 1;
    letter-spacing: -0.03em;
    white-space: nowrap;
  }
  .exp-header-text h2 {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: clamp(2rem, 5vw, 4rem);
    text-transform: uppercase;
    letter-spacing: 0.02em;
    line-height: 1;
  }
  .exp-header-text h2 em { font-style: normal; color: var(--gold-bright); }
  .exp-header-text p { font-size: 0.9rem; color: var(--text-muted); margin-top: 0.8rem; max-width: 500px; line-height: 1.6; }

  .exp-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  }

  .exp-item {
    padding: 2.5rem 2rem;
    border-right: 1px solid rgba(240,236,224,0.08);
    border-bottom: 1px solid rgba(240,236,224,0.08);
    transition: background 0.2s;
    position: relative;
    overflow: hidden;
  }
  .exp-item::before {
    content: '';
    position: absolute;
    left: 0; top: 0;
    width: 3px; height: 100%;
    background: var(--red);
    transform: scaleY(0);
    transition: transform 0.3s;
    transform-origin: bottom;
  }
  .exp-item:hover { background: rgba(240,236,224,0.03); }
  .exp-item:hover::before { transform: scaleY(1); }
  .exp-item-num {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: 3rem;
    color: rgba(240,236,224,0.06);
    line-height: 1;
    margin-bottom: 0.5rem;
  }
  .exp-item-icon { font-size: 1.5rem; margin-bottom: 0.8rem; }
  .exp-item-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 1.1rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }
  .exp-item-desc { font-size: 0.85rem; color: var(--text-muted); line-height: 1.6; }

  /* ORGS */
  .orgs-band {
    border-top: 2px solid rgba(240,236,224,0.1);
    display: grid;
    grid-template-columns: 1fr 1fr;
  }
  @media (max-width: 640px) { .orgs-band { grid-template-columns: 1fr; } }

  .org-panel {
    padding: 4rem 4%;
    border-right: 1px solid rgba(240,236,224,0.1);
    position: relative;
    overflow: hidden;
  }
  .org-panel:last-child { border-right: none; }
  .org-panel.gold-p { background: rgba(212,145,10,0.04); }
  .org-panel.red-p { background: rgba(204,26,26,0.06); }

  .op-label {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 0.7rem;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    margin-bottom: 0.8rem;
  }
  .op-label.gold { color: var(--gold-bright); }
  .op-label.red { color: var(--red-bright); }

  .op-name {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: clamp(1.8rem, 4vw, 3rem);
    text-transform: uppercase;
    letter-spacing: 0.02em;
    line-height: 1;
    margin-bottom: 1.5rem;
  }
  .op-name.gold { color: var(--gold-bright); }
  .op-name.red { color: var(--red-bright); }

  .op-desc { font-size: 0.9rem; color: var(--text-muted); line-height: 1.7; max-width: 380px; }

  /* SPONSORS */
  .sponsors-row-section {
    border-top: 2px solid rgba(240,236,224,0.1);
    padding: 4rem 4%;
  }
  .sr-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid rgba(240,236,224,0.1);
    flex-wrap: wrap;
    gap: 1rem;
  }
  .sr-header h3 {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: 1.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .sr-header a {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 0.75rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--gold-bright);
    text-decoration: none;
  }
  .sr-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0;
    border: 1px solid rgba(240,236,224,0.1);
  }
  .sr-card {
    flex: 1;
    min-width: 160px;
    padding: 2rem 1.5rem;
    border-right: 1px solid rgba(240,236,224,0.1);
    text-align: center;
    transition: background 0.2s;
    display: flex; flex-direction: column; align-items: center; gap: 0.4rem;
  }
  .sr-card:last-child { border-right: none; }
  .sr-card:hover { background: rgba(240,236,224,0.03); }
  .src-n {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: 1.1rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  .src-n.gold { color: var(--gold-bright); }
  .src-n.red { color: var(--red-bright); }
  .src-r {
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    color: var(--text-muted);
    text-transform: uppercase;
  }
  .src-placeholder { font-size: 0.75rem; color: rgba(240,236,224,0.15); font-style: italic; }

  /* FINAL CTA */
  .final-cta {
    border-top: 2px solid var(--red);
    background: var(--black);
    padding: 0;
    position: relative;
    overflow: hidden;
  }
  .cta-inner {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    padding: 5rem 4%;
    gap: 3rem;
    flex-wrap: wrap;
  }
  @media (max-width: 640px) { .cta-inner { grid-template-columns: 1fr; } }

  .cta-text h2 {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: clamp(3rem, 7vw, 6rem);
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 0.95;
  }
  .cta-text h2 .red { color: var(--red-bright); }
  .cta-text h2 .gold { color: var(--gold-bright); }
  .cta-text p {
    font-size: 1rem;
    color: var(--text-muted);
    margin-top: 1.2rem;
    max-width: 450px;
    line-height: 1.7;
  }

  .cta-action { display: flex; flex-direction: column; gap: 1rem; align-items: flex-end; }
  @media (max-width: 640px) { .cta-action { align-items: flex-start; } }

  .big-register-btn {
    background: var(--red);
    color: var(--white);
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: 1rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    padding: 1.2rem 3rem;
    border: none;
    cursor: crosshair;
    text-decoration: none;
    display: inline-block;
    transition: all 0.15s;
    white-space: nowrap;
  }
  .big-register-btn:hover { background: var(--red-bright); transform: skew(-1deg); }
  .cta-note {
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .cta-bg-text {
    position: absolute;
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: 20vw;
    color: rgba(240,236,224,0.02);
    letter-spacing: -0.04em;
    bottom: -2rem;
    right: -2rem;
    pointer-events: none;
    text-transform: uppercase;
    line-height: 1;
  }

  footer {
    background: var(--gray);
    border-top: 1px solid rgba(240,236,224,0.1);
    padding: 1.5rem 4%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
  }
  footer .gold { color: var(--gold-bright); }
  footer .red { color: var(--red-bright); }

  /* Animation */
  @keyframes fadeIn { from { opacity:0; transform: translateY(20px); } to { opacity:1; transform: translateY(0); } }
  .hero-left > * { animation: fadeIn 0.8s ease forwards; }
  .stamp-row { animation-delay: 0.1s; opacity: 0; }
  .hero-h1 { animation-delay: 0.3s; opacity: 0; }
  .hero-desc { animation-delay: 0.5s; opacity: 0; }
  .hero-cta-row { animation-delay: 0.7s; opacity: 0; }

  @media (max-width: 480px) {
    .hero-cta-row { flex-direction: column; }
    .brutal-btn { text-align: center; }
  }
</style>
</head>
<body>

<nav>
  <div class="nav-left">
    <div class="nav-segment expo">Garankuwa Expo</div>
    <div class="nav-segment gkss">GKSS–SMU</div>
  </div>
  <div class="nav-cta-wrap">
    <a href="#register" class="nav-register">Register</a>
  </div>
</nav>

<!-- HERO -->
<section class="hero">
  <div class="burst-bg">
    <svg viewBox="0 0 800 600" preserveAspectRatio="xMidYMid slice">
      <g stroke="#f5a623" fill="none">
        <!-- Radial lines emanating from center-right like GKSS poster -->
        <line x1="600" y1="300" x2="0" y2="0" stroke-width="0.5" opacity="0.5"/>
        <line x1="600" y1="300" x2="100" y2="0" stroke-width="0.5" opacity="0.5"/>
        <line x1="600" y1="300" x2="200" y2="0" stroke-width="0.5" opacity="0.5"/>
        <line x1="600" y1="300" x2="300" y2="0" stroke-width="0.5" opacity="0.5"/>
        <line x1="600" y1="300" x2="400" y2="0" stroke-width="0.5" opacity="0.5"/>
        <line x1="600" y1="300" x2="500" y2="0" stroke-width="0.5" opacity="0.5"/>
        <line x1="600" y1="300" x2="600" y2="0" stroke-width="0.5" opacity="0.5"/>
        <line x1="600" y1="300" x2="700" y2="0" stroke-width="0.5" opacity="0.5"/>
        <line x1="600" y1="300" x2="800" y2="0" stroke-width="0.5" opacity="0.5"/>
        <line x1="600" y1="300" x2="0" y2="600" stroke-width="0.5" opacity="0.5"/>
        <line x1="600" y1="300" x2="100" y2="600" stroke-width="0.5" opacity="0.5"/>
        <line x1="600" y1="300" x2="200" y2="600" stroke-width="0.5" opacity="0.5"/>
        <line x1="600" y1="300" x2="300" y2="600" stroke-width="0.5" opacity="0.5"/>
        <line x1="600" y1="300" x2="400" y2="600" stroke-width="0.5" opacity="0.5"/>
        <line x1="600" y1="300" x2="500" y2="600" stroke-width="0.5" opacity="0.5"/>
        <line x1="600" y1="300" x2="700" y2="600" stroke-width="0.5" opacity="0.5"/>
        <line x1="600" y1="300" x2="800" y2="600" stroke-width="0.5" opacity="0.5"/>
        <line x1="600" y1="300" x2="0" y2="150" stroke-width="0.5" opacity="0.5"/>
        <line x1="600" y1="300" x2="0" y2="300" stroke-width="0.5" opacity="0.5"/>
        <line x1="600" y1="300" x2="0" y2="450" stroke-width="0.5" opacity="0.5"/>
        <line x1="600" y1="300" x2="800" y2="150" stroke-width="0.5" opacity="0.5"/>
        <line x1="600" y1="300" x2="800" y2="300" stroke-width="0.5" opacity="0.5"/>
        <line x1="600" y1="300" x2="800" y2="450" stroke-width="0.5" opacity="0.5"/>
      </g>
    </svg>
  </div>

  <!-- TOP BAR -->
  <div class="hero-topbar">
    <span>⚡ Change is Coming</span>
    <span>26 March 2026 · Garankuwa</span>
    <span>The Future Is Here ⚡</span>
  </div>

  <div class="hero-content">
    <div class="hero-left">
      <div class="stamp-row">
        <span class="stamp gold">Career Tech Expo</span>
        <span class="stamp red">GKSS–SMU</span>
        <span class="stamp white">Free Entry</span>
      </div>

      <h1 class="hero-h1">
        <span class="w1">THE</span>
        <span class="w2">FUTURE</span>
        <span class="w3">IS HERE</span>
      </h1>

      <p class="hero-desc">The Garankuwa Career Tech Expo is a high-energy, one-day event bringing real tech experiences to students. Build AI apps, meet industry professionals, and discover your career path. Organised by GKSS–SMU — students, for students.</p>

      <div class="hero-cta-row">
        <a href="#register" class="brutal-btn primary">Register Now — Free</a>
        <a href="#experience" class="brutal-btn outline">What's Inside</a>
